/**
 * Definition for a binary tree node.
 * public class TreeNode {
 * int val;
 * TreeNode left;
 * TreeNode right;
 * TreeNode() {}
 * TreeNode(int val) { this.val = val; }
 * TreeNode(int val, TreeNode left, TreeNode right) {
 * this.val = val;
 * this.left = left;
 * this.right = right;
 * }
 * }
 */
class Solution {
    public int sumRootToLeaf(TreeNode root) {
        return dfs(root, 0);
    }
    
    private int dfs(TreeNode node, int currentSum) {
        // Base case: empty node contributes nothing to the sum
        if (node == null) {
            return 0;
        }
        
        // Update the running binary value
        currentSum = (currentSum << 1) | node.val;
        
        // If it's a leaf node, return the completed path value
        if (node.left == null && node.right == null) {
            return currentSum;
        }
        
        // Otherwise, traverse left and right subtrees and accumulate their path sums
        return dfs(node.left, currentSum) + dfs(node.right, currentSum);
    }
}
