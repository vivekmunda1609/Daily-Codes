import java.util.HashMap;
import java.util.Map;

class Solution {
    // Union-Find / Disjoint Set Class
    class DisjointSet {
        int[] parent;

        public DisjointSet(int n) {
            parent = new int[n];
            for (int i = 0; i < n; i++) {
                parent[i] = i;
            }
        }

        public int find(int i) {
            if (parent[i] == i) {
                return i;
            }
            return parent[i] = find(parent[i]); // Path compression
        }

        public void union(int i, int j) {
            int rootI = find(i);
            int rootJ = find(j);
            if (rootI != rootJ) {
                parent[rootI] = rootJ;
            }
        }
    }

    public int minimumHammingDistance(int[] source, int[] target, int[][] allowedSwaps) {
        int n = source.length;
        DisjointSet dsu = new DisjointSet(n);

        // Step 1: Connect indices that can be swapped
        for (int[] swap : allowedSwaps) {
            dsu.union(swap[0], swap[1]);
        }

        // Step 2: Group source elements by their component root ID
        // Map: Root ID -> (Map: Element Value -> Frequency)
        Map<Integer, Map<Integer, Integer>> componentMap = new HashMap<>();
        for (int i = 0; i < n; i++) {
            int root = dsu.find(i);
            componentMap.putIfAbsent(root, new HashMap<>());
            Map<Integer, Integer> countMap = componentMap.get(root);
            countMap.put(source[i], countMap.getOrDefault(source[i], 0) + 1);
        }

        // Step 3: Match against the target array to find unavoidable mismatches
        int hammingDistance = 0;
        for (int i = 0; i < n; i++) {
            int root = dsu.find(i);
            Map<Integer, Integer> countMap = componentMap.get(root);
            int targetVal = target[i];

            // Check if the required target number is available in this component pool
            if (countMap.containsKey(targetVal) && countMap.get(targetVal) > 0) {
                countMap.put(targetVal, countMap.get(targetVal) - 1);
            } else {
                // If it's missing, this position contributes to the Hamming distance
                hammingDistance++;
            }
        }

        return hammingDistance;
    }
}
