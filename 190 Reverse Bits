Link : https://leetcode.com/problems/reverse-bits/?envType=daily-question&envId=2026-05-20

public class Solution {
    public int reverseBits(int n) {
        int result = 0;
        
        for (int i = 0; i < 32; i++) {
            result <<= 1;
            result |= (n & 1);
            n >>>= 1;
        }
        
        return result;
    }
}
