import java.util.Arrays;

class Solution {
    private int side;
    private long[] nums;
    private int k;

    public int maxDistance(int side, int[][] points, int k) {
        this.side = side;
        this.k = k;
        int n = points.length;
        this.nums = new long[n];

        // Step 1: Flatten 2D perimeter coordinates into 1D continuous scalar values
        for (int i = 0; i < n; i++) {
            int x = points[i][0];
            int y = points[i][1];
            if (x == 0) {
                nums[i] = (long) y;
            } else if (y == side) {
                nums[i] = (long) side + x;
            } else if (x == side) {
                nums[i] = (long) side * 3 - y;
            } else {
                nums[i] = (long) side * 4 - x;
            }
        }

        // Sort the points in clockwise perimeter order
        Arrays.sort(nums);

        // Step 2: Binary Search over the possible minimum Manhattan distance
        int l = 1, r = side;
        while (l < r) {
            int mid = (l + r + 1) >> 1; // Round up to avoid infinite loops
            if (check(mid)) {
                l = mid; // Try for a larger minimum distance
            } else {
                r = mid - 1; // Reduce distance expectations
            }
        }

        return l;
    }

    // Step 3: Greedy check function to validate if a minimum distance 'lo' is possible
    private boolean check(int lo) {
        long totalPerimeter = (long) side * 4;

        // Try every point as a potential starting anchor element
        for (int i = 0; i < nums.length; i++) {
            long start = nums[i];
            // The last chosen point cannot wrap-around past this boundary threshold
            long endThreshold = start + totalPerimeter - lo;
            long cur = start;
            boolean possible = true;

            // Greedily find the remaining k - 1 points
            for (int j = 0; j < k - 1; j++) {
                long targetDistance = cur + lo;
                int idx = lowerBound(nums, targetDistance);

                // If no point satisfies the distance or it exceeds the allowed wrap boundary
                if (idx == nums.length || nums[idx] > endThreshold) {
                    possible = false;
                    break;
                }
                cur = nums[idx]; // Leap to the newly found point
            }

            if (possible) {
                return true;
            }
        }
        return false;
    }

    // Binary search helper to find the first element >= target
    private int lowerBound(long[] arr, long target) {
        int left = 0, right = arr.length;
        while (left < right) {
            int mid = (left + right) >>> 1;
            if (arr[mid] < target) {
                left = mid + 1;
            } else {
                right = mid;
            }
        }
        return left;
    }
}
