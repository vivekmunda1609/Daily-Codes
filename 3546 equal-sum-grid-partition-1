
class Solution {
    public boolean canPartitionGrid(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;
        long totalSum = 0;
        
        // Step 1: Compute the total sum of all elements
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                totalSum += grid[i][j];
            }
        }
        
        // If the total sum is odd, it cannot be divided into two equal halves
        if (totalSum % 2 != 0) {
            return false;
        }
        
        long target = totalSum / 2;
        
        // Step 2: Check for a valid Horizontal Cut
        long horizontalPrefix = 0;
        for (int i = 0; i < m - 1; i++) { // Stop before the last row (non-empty section rule)
            for (int j = 0; j < n; j++) {
                horizontalPrefix += grid[i][j];
            }
            if (horizontalPrefix == target) {
                return true;
            }
        }
        
        // Step 3: Check for a valid Vertical Cut
        long verticalPrefix = 0;
        for (int j = 0; j < n - 1; j++) { // Stop before the last column (non-empty section rule)
            for (int i = 0; i < m; i++) {
                verticalPrefix += grid[i][j];
            }
            if (verticalPrefix == target) {
                return true;
            }
        }
        
        return false;
    }
}
