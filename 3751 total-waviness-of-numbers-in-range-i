class Solution {
    public int totalWaviness(int num1, int num2) {
        int totalWavinessSum = 0;
        
        // Iterate through each number in the inclusive range
        for (int i = num1; i <= num2; i++) {
            totalWavinessSum += getWaviness(i);
        }
        
        return totalWavinessSum;
    }
    
    // Helper method to calculate the waviness score of a single number
    private int getWaviness(int num) {
        // Any number with fewer than 3 digits has a waviness of 0
        if (num < 100) {
            return 0;
        }
        
        String s = Integer.toString(num);
        int len = s.length();
        int count = 0;
        
        // The first and last digits cannot be peaks or valleys
        for (int i = 1; i < len - 1; i++) {
            char curr = s.charAt(i);
            char prev = s.charAt(i - 1);
            char next = s.charAt(i + 1);
            
            // Check if current digit is a Peak
            if (curr > prev && curr > next) {
                count++;
            } 
            // Check if current digit is a Valley
            else if (curr < prev && curr < next) {
                count++;
            }
        }
        
        return count;
    }
}
